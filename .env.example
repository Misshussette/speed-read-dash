# =============================================================================
# StintLab — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For Lovable Cloud, these are auto-populated — do NOT edit .env manually.
# For a local / self-hosted Supabase instance, point to your own instance.
# =============================================================================

# ---------- Frontend (Vite — exposed to the browser) ----------

# Base URL of the Supabase instance (e.g. http://localhost:54321 for local)
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"

# Supabase anon / publishable key (safe to expose in the browser)
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."

# Supabase project ID (used for display / config purposes only)
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# ---------- Edge Functions (Deno runtime — server-side only) -----------------
# These are injected automatically when running on Supabase-hosted Edge Functions.
# For local `supabase functions serve` they come from supabase/.env or --env-file.

# Same as VITE_SUPABASE_URL but without the VITE_ prefix
# SUPABASE_URL="https://<project-ref>.supabase.co"

# Same value as VITE_SUPABASE_PUBLISHABLE_KEY
# SUPABASE_ANON_KEY="eyJ..."

# Service-role key — NEVER expose in the browser.
# Required by edge functions for admin-level DB / storage operations.
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Postgres connection string (used by some edge functions if needed)
# SUPABASE_DB_URL="postgresql://postgres:<password>@<host>:5432/postgres"

# ---------- Optional / Third-party -----------------------------------------

# Lovable AI gateway key (set automatically on Lovable Cloud)
# LOVABLE_API_KEY="..."
